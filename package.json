{
  "name": "gitch",
  "version": "1.0.0",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "ansis": "^4.2.0",
    "cac": "^7.0.0"
  },
  "bin": {
    "gitch": "./index.ts"
  },
  "description": "Git account switcher — manage multiple Git identities",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Joselay/gitch.git"
  },
  "keywords": [
    "git",
    "ssh",
    "git-account",
    "git-profile",
    "cli"
  ],
  "files": [
    "src",
    "index.ts",
    "dist"
  ],
  "scripts": {
    "dev": "bun --watch run index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "bun run lint && bun run typecheck && bun test",
    "build": "bun build ./index.ts --compile --outfile dist/gitch",
    "prepublishOnly": "bun run check && bun run build"
  },
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "^1.3.12",
    "typescript": "^6"
  }
}
